import java.util.*;

class Codechef
{
    public static void main(String[] args) throws java.lang.Exception
    {
        Scanner sc = new Scanner(System.in);

        int T = sc.nextInt();

        while (T-- > 0)
        {
            int A = sc.nextInt();
            int B = sc.nextInt();

            System.out.println(A % B);
        }

        sc.close();
    }
}
