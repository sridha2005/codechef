import java.util.*;

class Codechef
{
    public static void main(String[] args) throws java.lang.Exception
    {
        Scanner sc = new Scanner(System.in);

        int N = sc.nextInt();
        int K = sc.nextInt();

        int count = 0;

        for (int i = 0; i < N; i++)
        {
            int num = sc.nextInt();
            if (num % K == 0)
            {
                count++;
            }
        }

        System.out.println(count);
        sc.close();
    }
}
