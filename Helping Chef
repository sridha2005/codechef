import java.util.*;

class Codechef
{
    public static void main(String[] args) throws Exception
    {
        Scanner sc = new Scanner(System.in);

        int T = sc.nextInt();

        while (T-- > 0)
        {
            int N = sc.nextInt();

            if (N < 10)
            {
                System.out.println("Thanks for helping Chef!");
            }
            else
            {
                System.out.println("-1");
            }
        }
    }
}
